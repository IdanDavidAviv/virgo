{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "out",
    "lib": [
      "ES2022"
    ],
    "sourceMap": true,
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@extension/*": ["src/extension/*"],
      "@core/*": ["src/extension/core/*"],
      "@vscode/*": ["src/extension/vscode/*"],
      "@webview/*": ["src/webview/*"],
      "@common/*": ["src/common/*"]
    }
  },
  "exclude": [
    "node_modules"
  ]
}
