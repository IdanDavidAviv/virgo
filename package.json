{
  "name": "readme-preview-read-aloud",
  "displayName": "README Preview Read Aloud",
  "description": "Reads markdown previews aloud using speech synthesis",
  "version": "0.0.1",
  "publisher": "IdanDavidAviv",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onStartupFinished",
    "onView:readme-preview-read-aloud.speech-engine"
  ],
  "contributes": {
    "commands": [
      {
        "command": "readme-preview-read-aloud.play",
        "title": "Read Aloud",
        "icon": "$(play)"
      },
      {
        "command": "readme-preview-read-aloud.pause",
        "title": "Pause",
        "icon": "$(debug-pause)"
      },
      {
        "command": "readme-preview-read-aloud.stop",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "readme-preview-read-aloud.show-dashboard",
        "title": "Show Read Aloud Dashboard",
        "icon": "$(megaphone)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "readme-read-aloud",
          "title": "Read Aloud",
          "icon": "$(megaphone)"
        }
      ]
    },
    "views": {
      "readme-read-aloud": [
        {
          "id": "readme-preview-read-aloud.speech-engine",
          "type": "webview",
          "name": "Audio Engine",
          "icon": "$(megaphone)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "say": "^0.16.0"
  }
}
