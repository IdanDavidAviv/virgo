{
  "name": "readme-preview-read-aloud",
  "displayName": "README Preview Read Aloud",
  "description": "Reads markdown previews aloud using speech synthesis",
  "version": "1.0.1",
  "publisher": "IdanDavidAviv",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IdanDavidAviv/readme-preview-read-aloud.git"
  },
  "homepage": "https://github.com/IdanDavidAviv/readme-preview-read-aloud#readme",
  "bugs": {
    "url": "https://github.com/IdanDavidAviv/readme-preview-read-aloud/issues"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "qna": "marketplace",
  "keywords": [
    "markdown",
    "tts",
    "read aloud",
    "accessibility",
    "speech",
    "preview"
  ],
  "icon": "icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "readme-preview-read-aloud.play",
        "title": "Read Aloud",
        "icon": "$(play)"
      },
      {
        "command": "readme-preview-read-aloud.pause",
        "title": "Pause",
        "icon": "$(debug-pause)"
      },
      {
        "command": "readme-preview-read-aloud.stop",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "readme-preview-read-aloud.show-dashboard",
        "title": "Show Read Aloud Dashboard",
        "icon": "$(refresh)"
      },
      {
        "command": "readme-preview-read-aloud.read-selection",
        "title": "Read Selection",
        "icon": "$(play)"
      },
      {
        "command": "readme-preview-read-aloud.read-from-cursor",
        "title": "Read Aloud From Here",
        "icon": "$(debug-start-from-here)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "readme-read-aloud",
          "title": "Read Aloud",
          "icon": "dist/icon.svg"
        }
      ]
    },
    "views": {
      "readme-read-aloud": [
        {
          "id": "readme-preview-read-aloud.speech-engine",
          "type": "webview",
          "name": "Audio Engine",
          "icon": "$(unmute)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "readme-preview-read-aloud.show-dashboard",
          "when": "view == readme-preview-read-aloud.speech-engine",
          "group": "navigation@1"
        },
        {
          "command": "readme-preview-read-aloud.stop",
          "when": "view == readme-preview-read-aloud.speech-engine",
          "group": "navigation@2"
        }
      ],
      "editor/title": [
        {
          "command": "readme-preview-read-aloud.play",
          "when": "editorLangId == markdown",
          "group": "navigation@1"
        },
        {
          "command": "readme-preview-read-aloud.stop",
          "when": "editorLangId == markdown",
          "group": "navigation@2"
        },
        {
          "command": "readme-preview-read-aloud.read-selection",
          "when": "editorHasSelection",
          "group": "navigation@3"
        },
        {
          "command": "readme-preview-read-aloud.show-dashboard",
          "when": "editorLangId == markdown",
          "group": "navigation@4"
        }
      ],
      "editor/context": [
        {
          "command": "readme-preview-read-aloud.read-selection",
          "group": "modification",
          "when": "editorHasSelection"
        },
        {
          "command": "readme-preview-read-aloud.read-from-cursor",
          "group": "modification",
          "when": "editorLangId == markdown"
        }
      ]
    },
    "configuration": {
      "title": "Read Aloud",
      "properties": {
        "readAloud.bridgePort": {
          "type": "number",
          "default": 3001,
          "description": "Port used by the internal audio engine bridge."
        }
      }
    },
    "keybindings": [
      {
        "command": "readme-preview-read-aloud.play",
        "key": "alt+r",
        "when": "editorLangId == markdown"
      },
      {
        "command": "readme-preview-read-aloud.stop",
        "key": "alt+s"
      },
      {
        "command": "readme-preview-read-aloud.read-from-cursor",
        "key": "alt+shift+r",
        "when": "editorLangId == markdown"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "node esbuild.js --mode=development",
    "watch": "node esbuild.js --watch --mode=development",
    "build": "node esbuild.js --mode=production",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.27.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.1.1",
    "msedge-tts": "^2.0.4",
    "say": "^0.16.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}
