{
  "name": "readme-preview-read-aloud",
  "displayName": "README Preview Read Aloud",
  "description": "Reads markdown previews aloud using speech synthesis",
  "version": "0.0.1",
  "publisher": "IdanDavidAviv",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "readme-preview-read-aloud.play",
        "title": "Read Aloud",
        "icon": "$(play)"
      },
      {
        "command": "readme-preview-read-aloud.pause",
        "title": "Pause",
        "icon": "$(debug-pause)"
      },
      {
        "command": "readme-preview-read-aloud.stop",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "readme-preview-read-aloud.show-dashboard",
        "title": "Show Read Aloud Dashboard",
        "icon": "$(refresh)"
      },
      {
        "command": "readme-preview-read-aloud.read-selection",
        "title": "Read Selection",
        "icon": "$(play)"
      },
      {
        "command": "antigravity.openMissionControl",
        "title": "Open Mission Control (Editor Tab)",
        "icon": "$(rocket)"
      },
      {
        "command": "readme-preview-read-aloud.read-from-cursor",
        "title": "Read Aloud From Here",
        "icon": "$(debug-start-from-here)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "readme-read-aloud",
          "title": "Read Aloud",
          "icon": "$(unmute)"
        }
      ]
    },
    "views": {
      "readme-read-aloud": [
        {
          "id": "readme-preview-read-aloud.speech-engine",
          "type": "webview",
          "name": "Audio Engine",
          "icon": "$(unmute)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "readme-preview-read-aloud.show-dashboard",
          "when": "view == readme-preview-read-aloud.speech-engine",
          "group": "navigation@1"
        },
        {
          "command": "readme-preview-read-aloud.stop",
          "when": "view == readme-preview-read-aloud.speech-engine",
          "group": "navigation@2"
        }
      ],
      "editor/title": [
        {
          "command": "readme-preview-read-aloud.play",
          "when": "editorLangId == markdown",
          "group": "navigation@1"
        },
        {
          "command": "readme-preview-read-aloud.stop",
          "when": "editorLangId == markdown",
          "group": "navigation@2"
        },
        {
          "command": "readme-preview-read-aloud.read-selection",
          "when": "editorHasSelection",
          "group": "navigation@3"
        },
        {
          "command": "readme-preview-read-aloud.show-dashboard",
          "when": "editorLangId == markdown",
          "group": "navigation@4"
        }
      ],
      "editor/context": [
        {
          "command": "readme-preview-read-aloud.read-selection",
          "group": "modification",
          "when": "editorHasSelection"
        },
        {
          "command": "readme-preview-read-aloud.read-from-cursor",
          "group": "modification",
          "when": "editorLangId == markdown"
        }
      ]
    },
    "configuration": {
      "title": "Read Aloud",
      "properties": {
        "readAloud.bridgePort": {
          "type": "number",
          "default": 3001,
          "description": "Port used by the internal audio engine bridge."
        }
      }
    },
    "keybindings": [
      {
        "command": "readme-preview-read-aloud.play",
        "key": "alt+r",
        "when": "editorLangId == markdown"
      },
      {
        "command": "readme-preview-read-aloud.stop",
        "key": "alt+s"
      },
      {
        "command": "readme-preview-read-aloud.read-from-cursor",
        "key": "alt+shift+r",
        "when": "editorLangId == markdown"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "msedge-tts": "^2.0.4",
    "say": "^0.16.0",
    "ws": "^8.20.0"
  }
}
