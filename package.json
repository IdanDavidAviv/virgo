{
  "name": "readme-preview-read-aloud",
  "displayName": "README Preview Read Aloud",
  "description": "Reads markdown previews aloud using speech synthesis",
  "version": "2.0.6",
  "publisher": "IdanDavidAviv",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IdanDavidAviv/readme-preview-read-aloud.git"
  },
  "homepage": "https://github.com/IdanDavidAviv/readme-preview-read-aloud#readme",
  "bugs": {
    "url": "https://github.com/IdanDavidAviv/readme-preview-read-aloud/issues"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "qna": "marketplace",
  "keywords": [
    "markdown",
    "tts",
    "read aloud",
    "accessibility",
    "speech",
    "preview"
  ],
  "icon": "assets/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "readme-preview-read-aloud.play",
        "title": "Read Aloud",
        "icon": "$(play)"
      },
      {
        "command": "readme-preview-read-aloud.pause",
        "title": "Pause",
        "icon": "$(debug-pause)"
      },
      {
        "command": "readme-preview-read-aloud.stop",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "readme-preview-read-aloud.show-dashboard",
        "title": "Show Read Aloud Dashboard",
        "icon": "$(layout-sidebar-right)"
      },
      {
        "command": "readme-preview-read-aloud.read-from-cursor",
        "title": "Read Aloud From Here",
        "icon": "$(debug-start-from-here)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "readme-read-aloud",
          "title": "Read Aloud",
          "icon": "dist/icon.svg"
        }
      ]
    },
    "views": {
      "readme-read-aloud": [
        {
          "id": "readme-preview-read-aloud.speech-engine",
          "type": "webview",
          "name": "Audio Engine",
          "icon": "$(unmute)"
        }
      ]
    },
    "menus": {
      "view/title": [],
      "editor/title": [
        {
          "command": "readme-preview-read-aloud.play",
          "when": "editorLangId == markdown",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "readme-preview-read-aloud.read-from-cursor",
          "group": "modification",
          "when": "editorLangId == markdown"
        }
      ]
    },
    "configuration": {
      "title": "Read Aloud",
      "properties": {
        "readAloud.logging.level": {
          "type": "string",
          "enum": [
            "Standard",
            "Verbose"
          ],
          "default": "Standard",
          "description": "Control the verbosity of diagnostic logs. Standard uses shorthand and summarization. Verbose logs raw data blobs."
        },
        "readAloud.playback.rate": {
          "type": "number",
          "default": 0,
          "minimum": -10,
          "maximum": 10,
          "description": "Speech rate (speed). Higher is faster."
        },
        "readAloud.playback.volume": {
          "type": "number",
          "default": 50,
          "minimum": 0,
          "maximum": 100,
          "description": "Speech volume level."
        },
        "readAloud.playback.voice": {
          "type": "string",
          "default": "en-US-SteffanNeural",
          "description": "The voice to use for neural synthesis."
        },
        "readAloud.playback.engineMode": {
          "type": "string",
          "enum": [
            "neural",
            "local"
          ],
          "default": "neural",
          "description": "Switch between high-quality Cloud Neural voices (requires internet) and standard Local SAPI voices (offline)."
        },
        "readAloud.playback.autoPlayMode": {
          "type": "string",
          "enum": [
            "auto",
            "chapter",
            "row"
          ],
          "default": "auto",
          "description": "Control how playback advances. 'auto' reads the entire document. 'chapter' stops at chapter ends. 'row' stops after each sentence."
        },
        "readAloud.playback.autoPlayOnInjection": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start playback when a new MCP snippet is injected (Vocal Sync). Use with caution to avoid unexpected audio."
        },
        "readAloud.playback.jumpDelayMs": {
          "type": "number",
          "default": 200,
          "description": "Delay in milliseconds before prefetching or pushing audio segments to the webview."
        },
        "readAloud.cache.maxSizeMb": {
          "type": "number",
          "default": 50,
          "description": "Maximum size of the audio cache in megabytes. Older segments are pruned automatically."
        },
        "readAloud.network.retryAttempts": {
          "type": "number",
          "default": 3,
          "description": "Maximum number of retries for neural synthesis before giving up."
        }
      }
    },
    "keybindings": [
      {
        "command": "readme-preview-read-aloud.play",
        "key": "alt+r",
        "when": "editorLangId == markdown"
      },
      {
        "command": "readme-preview-read-aloud.stop",
        "key": "alt+s"
      },
      {
        "command": "readme-preview-read-aloud.read-from-cursor",
        "key": "alt+shift+r",
        "when": "editorLangId == markdown"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "node esbuild.js --mode=development",
    "watch": "node esbuild.js --watch --mode=development",
    "build": "node esbuild.js --mode=production",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "package": "node scripts/package.js",
    "release:audit": "node .agent/skills/version_sentinel/scripts/git_history_audit.js --diff",
    "release:verify": "node .agent/skills/version_sentinel/scripts/manage_version.js",
    "release": "npm run release:verify && npm run lint && npm run build && npm run package && node .agent/skills/release_prestige/scripts/verify_artifact.js",
    "release:patch": "node .agent/skills/version_sentinel/scripts/manage_version.js --bump patch && npm run release",
    "release:minor": "node .agent/skills/version_sentinel/scripts/manage_version.js --bump minor && npm run release",
    "release:major": "node .agent/skills/version_sentinel/scripts/manage_version.js --bump major && npm run release"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@vitest/coverage-v8": "^4.1.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "markdown-it": "^14.1.1",
    "msedge-tts": "^2.0.4"
  }
}
