{
  "name": "virgo",
  "displayName": "Virgo",
  "description": "AI that talks to YOU. Neural narration, MCP-powered, for VS Code.",
  "version": "2.8.0",
  "license": "SEE LICENSE IN LICENSE",
  "publisher": "IdanDavidAviv",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IdanDavidAviv/virgo.git"
  },
  "enabledApiProposals": [
    "chatContextProvider",
    "chatProvider"
  ],
  "homepage": "https://github.com/IdanDavidAviv/virgo#readme",
  "bugs": {
    "url": "https://github.com/IdanDavidAviv/virgo/issues"
  },
  "categories": [
    "AI",
    "Education",
    "Other"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "qna": "marketplace",
  "keywords": [
    "markdown",
    "tts",
    "read aloud",
    "accessibility",
    "speech",
    "preview",
    "mcp",
    "ai",
    "neural",
    "agent",
    "cursor",
    "copilot",
    "narration",
    "text to speech"
  ],
  "sponsor": {
    "url": "https://www.buymeacoffee.com/idandavidaviv"
  },
  "galleryBanner": {
    "color": "#0d0d1a",
    "theme": "dark"
  },
  "icon": "assets/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "virgo.play",
        "title": "Virgo: Play",
        "icon": "$(play)"
      },
      {
        "command": "virgo.pause",
        "title": "Pause",
        "icon": "$(debug-pause)"
      },
      {
        "command": "virgo.stop",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "virgo.show-dashboard",
        "title": "Show Virgo Dashboard",
        "icon": "$(layout-sidebar-right)"
      },
      {
        "command": "virgo.read-from-cursor",
        "title": "Read From Here",
        "icon": "$(debug-start-from-here)"
      },
      {
        "command": "virgo.prev-chapter",
        "title": "Previous Chapter",
        "icon": "$(arrow-left)"
      },
      {
        "command": "virgo.next-chapter",
        "title": "Next Chapter",
        "icon": "$(arrow-right)"
      },
      {
        "command": "virgo.prev-sentence",
        "title": "Previous Sentence",
        "icon": "$(triangle-left)"
      },
      {
        "command": "virgo.next-sentence",
        "title": "Next Sentence",
        "icon": "$(triangle-right)"
      },
      {
        "command": "virgo.restart-mcp",
        "title": "Virgo: Restart MCP Bridge",
        "icon": "$(refresh)"
      },
      {
        "command": "virgo.restart-extension",
        "title": "Virgo: Full Extension Restart",
        "icon": "$(sync)"
      },
      {
        "command": "virgo.refresh-voices",
        "title": "Virgo: Refresh Voices",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "virgo",
          "title": "Virgo",
          "icon": "dist/icon.svg"
        }
      ]
    },
    "views": {
      "virgo": [
        {
          "id": "virgo.speech-engine",
          "type": "webview",
          "name": "Audio Engine",
          "icon": "$(unmute)"
        }
      ]
    },
    "menus": {
      "view/title": [],
      "editor/title": [
        {
          "command": "virgo.play",
          "when": "editorLangId == markdown",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "virgo.read-from-cursor",
          "group": "modification",
          "when": "editorLangId == markdown"
        }
      ]
    },
    "configuration": {
      "title": "Virgo",
      "properties": {
        "readAloud.logging.level": {
          "type": "string",
          "enum": [
            "Standard",
            "Verbose"
          ],
          "default": "Standard",
          "description": "Control the verbosity of diagnostic logs. Standard uses shorthand and summarization. Verbose logs raw data blobs."
        },
        "readAloud.playback.rate": {
          "type": "number",
          "default": 1,
          "minimum": 0.5,
          "maximum": 2,
          "description": "Speech rate (speed). Higher is faster."
        },
        "readAloud.playback.volume": {
          "type": "number",
          "default": 50,
          "minimum": 0,
          "maximum": 100,
          "description": "Speech volume level."
        },
        "readAloud.playback.voice": {
          "type": "string",
          "default": "en-US-SteffanNeural",
          "description": "The voice to use for neural synthesis."
        },
        "readAloud.playback.engineMode": {
          "type": "string",
          "enum": [
            "neural",
            "local"
          ],
          "default": "neural",
          "description": "Switch between high-quality Cloud Neural voices (requires internet) and standard Local SAPI voices (offline)."
        },
        "readAloud.playback.autoPlayMode": {
          "type": "string",
          "enum": [
            "auto",
            "chapter",
            "row"
          ],
          "default": "auto",
          "description": "Control how playback advances. 'auto' reads the entire document. 'chapter' stops at chapter ends. 'row' stops after each sentence."
        },
        "readAloud.playback.autoPlayOnInjection": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start playback when a new MCP snippet is injected (Vocal Sync). Use with caution to avoid unexpected audio."
        },
        "readAloud.playback.jumpDelayMs": {
          "type": "number",
          "default": 200,
          "description": "Delay in milliseconds before prefetching or pushing audio segments to the webview."
        },
        "readAloud.cache.maxSizeMb": {
          "type": "number",
          "default": 50,
          "description": "Maximum size of the audio cache in megabytes. Older segments are pruned automatically."
        },
        "readAloud.network.retryAttempts": {
          "type": "number",
          "default": 3,
          "description": "Maximum number of retries for neural synthesis before giving up."
        },
        "readAloud.agent.autoInjectSITREP": {
          "type": "boolean",
          "default": true,
          "description": "Automatically inject a SITREP/Summary into Virgo when a task is completed (Multimodal Parity)."
        },
        "readAloud.playback.globalShortcuts": {
          "type": "boolean",
          "default": false,
          "description": "If enabled, navigation shortcuts (Arrows, Shift+Arrows) work globally when the extension is active. If disabled, they only work when focused on a Markdown editor or the Dashboard."
        },
        "virgo.system.rootDirectory": {
          "type": "string",
          "default": "virgo",
          "description": "The root directory name for Virgo data storage (sessions, protocols, media) under the antigravity directory. Defaults to 'virgo'. Change this if you want to partition different projects."
        }
      }
    },
    "keybindings": [
      {
        "command": "virgo.play",
        "key": "alt+r",
        "when": "editorLangId == markdown"
      },
      {
        "command": "virgo.stop",
        "key": "alt+s"
      },
      {
        "command": "virgo.read-from-cursor",
        "key": "alt+shift+r",
        "when": "editorLangId == markdown"
      },
      {
        "command": "virgo.prev-chapter",
        "key": "shift+left",
        "when": "editorLangId == markdown || config.readAloud.playback.globalShortcuts"
      },
      {
        "command": "virgo.next-chapter",
        "key": "shift+right",
        "when": "editorLangId == markdown || config.readAloud.playback.globalShortcuts"
      },
      {
        "command": "virgo.prev-sentence",
        "key": "left",
        "when": "editorLangId == markdown || config.readAloud.playback.globalShortcuts"
      },
      {
        "command": "virgo.next-sentence",
        "key": "right",
        "when": "editorLangId == markdown || config.readAloud.playback.globalShortcuts"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "node esbuild.js --mode=development",
    "watch": "node esbuild.js --watch --mode=development",
    "build": "node esbuild.js --mode=production",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:core": "vitest run tests/core",
    "test:mcp": "vitest run tests/mcp",
    "test:vscode": "vitest run tests/vscode",
    "test:webview": "vitest run tests/webview",
    "test:integration": "vitest run tests/**/*.integration.test.ts",
    "package": "node scripts/package.js",
    "release:audit": "node .agent/skills/release_authority/scripts/git_history_audit.js --diff",
    "release:verify": "node .agent/skills/release_authority/scripts/manage_version.js",
    "release:changelog-check": "node .agent/skills/release_authority/scripts/manage_version.js --check",
    "release:quality-gates": "npm run lint && npm run typecheck && npm run test && npm run build",
    "release:gates": "npm run release:verify && npm run release:quality-gates",
    "release:package": "npm run package && node .agent/skills/release_authority/scripts/verify_artifact.js",
    "release": "npm run release:gates && npm run release:package",
    "release:patch": "npm run release:quality-gates && npm run release:changelog-check && node .agent/skills/release_authority/scripts/manage_version.js --bump patch && npm run release:verify && npm run release:package",
    "release:minor": "npm run release:quality-gates && npm run release:changelog-check && node .agent/skills/release_authority/scripts/manage_version.js --bump minor && npm run release:verify && npm run release:package",
    "release:major": "npm run release:quality-gates && npm run release:changelog-check && node .agent/skills/release_authority/scripts/manage_version.js --bump major && npm run release:verify && npm run release:package",
    "release:patch:fast": "npm run release:changelog-check && node .agent/skills/release_authority/scripts/manage_version.js --bump patch && npm run release:verify && npm run release:package",
    "release:minor:fast": "npm run release:changelog-check && node .agent/skills/release_authority/scripts/manage_version.js --bump minor && npm run release:verify && npm run release:package",
    "release:major:fast": "npm run release:changelog-check && node .agent/skills/release_authority/scripts/manage_version.js --bump major && npm run release:verify && npm run release:package",
    "cdp:shell": "node .agent/skills/cdp_dev_cycle/cdp-controller.mjs shell",
    "cdp:status": "node .agent/skills/cdp_dev_cycle/cdp-controller.mjs status",
    "cdp:targets": "node .agent/skills/cdp_dev_cycle/cdp-controller.mjs targets",
    "cdp:launch": "node .agent/skills/cdp_dev_cycle/cdp-controller.mjs launch",
    "cdp:cleanup": "node .agent/skills/cdp_dev_cycle/cdp-controller.mjs cleanup-all",
    "dev:full-cycle": "npm run compile && npm run cdp:launch",
    "publish:mcp": "node .agent/skills/mcp_publisher/scripts/publish_mcp.js",
    "release:github": "node scripts/publish_github.js"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "playwright-core": "^1.59.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "markdown-it": "^14.1.1",
    "msedge-tts": "^2.0.4"
  }
}
