{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Extension (Dev)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extension=IdanDavidAviv.virgo",
        "--disable-extension=IdanDavidAviv.readme-preview-read-aloud",
        "--user-data-dir=${workspaceFolder}/.vscode/ext-dev-data"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "watch-dev"
    },
    {
      "name": "Extension (Prod)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extension=IdanDavidAviv.virgo",
        "--disable-extension=IdanDavidAviv.readme-preview-read-aloud",
        "--user-data-dir=${workspaceFolder}/.vscode/ext-dev-data"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "npm: build"
    }
  ]
}
