{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch-dev",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "🛠️ Mode",
          "endsPattern": "build (finished|failed)"
        },
        "pattern": {
          "regexp": "^.*$"
        }
      },
      "presentation": {
        "reveal": "never",
        "close": false
      },
      "group": "build"
    },
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$tsc",
      "label": "npm: compile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "build",
      "problemMatcher": "$tsc",
      "label": "npm: build",
      "group": "build"
    }
  ]
}
